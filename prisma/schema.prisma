generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Required for Supabase
}

model Vendor {
  id           String     @id @default(uuid())
  clerkId      String     @unique  // 👈 ADDED: Links DB to the Clerk user
  email        String     @unique  // 👈 ADDED: Stores their Google/Sign-up email

  name         String?
  businessType String?    


  tier         Int        @default(1)
  defaultTable String     @default("Counter")

  // --- BRANDING STUDIO FIELDS ---
  logoUrl      String?    // Optional: URL for their uploaded logo
  bannerUrl    String?    // Optional: URL for the top banner image
  primaryColor String     @default("#E5B35C") // Defaults to Pabee Gold
  theme        String     @default("dark")    // "dark" or "light"

  // ... (keep your existing relations like menus, orders, etc.)
  
  menuItems    MenuItem[]
  orders       Order[]
  promos       Promo[]
}

model MenuItem {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  name        String
  category    String
  price       Float
  prep        String   
  veg         Boolean  @default(true)
  available   Boolean  @default(true)
  imageUrl  String?
}

model Order {
  id            String      @id @default(uuid())
  vendorId      String
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
  tableId       String
  token         Int         @default(autoincrement())
  status        String      @default("received")
  kitchenStatus String      @default("pending")
  total         Float
  paymentMode   String
  customerPhone String?
  createdAt     DateTime    @default(now())
  
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  qty       Int
  price     Float
}

// --- NEW PROMO TABLE ---
model Promo {
  id            String    @id @default(uuid())
  vendorId      String
  code          String    // e.g., "DIWALI50" (We will convert this to UPPERCASE)
  type          String    // "FLAT" or "PERCENTAGE"
  value         Float     // e.g., 50 (₹50 off) or 15 (15% off)
  minOrderValue Float     @default(0) // Order must be >= this amount
  maxUses       Int?      // Null means unlimited. Otherwise, stops at this number.
  currentUses   Int       @default(0)
  expiresAt     DateTime? // Null means it never expires.
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  vendor        Vendor    @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, code]) // A vendor can't have two identical codes active
}